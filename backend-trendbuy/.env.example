DATABASE_URL=postgresql+asyncpg://trendbuy:trendbuy@localhost:5432/trendbuy
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=123456789
# Verifies incoming webhook calls really come from Telegram (see
# api/telegram.py + services/notifier.py::set_telegram_webhook) - required
# for per-user Telegram linking to work, not just the broadcast bot above.
# Also needs FRONTEND_URL below to be a real public HTTPS URL (Telegram
# refuses localhost/http webhooks). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=
# Optional: only needed if Expo push receipts should be authenticated (Expo access token).
EXPO_ACCESS_TOKEN=

# Magic-link login emails + per-favorite deal alerts. Any SMTP relay works
# (Gmail app password, Mailgun, Brevo, SES...) - if left blank, emails are
# just logged as "not sent" instead of failing the request.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# "Continuar con Google" (api/auth.py + services/google_auth.py) - optional,
# same graceful-degradation pattern as everything else here: leave both
# blank and the Google button just doesn't render, email magic-link login
# still works on its own.
#
# 1. console.cloud.google.com/apis/credentials -> Create Credentials ->
#    OAuth client ID -> Application type: Web application.
# 2. Authorized redirect URIs, add exactly (must match FRONTEND_URL below,
#    always through the /backend proxy - see api/auth.py::_google_redirect_uri):
#      http://localhost:3000/backend/api/v1/auth/google/callback   (local dev)
#      https://yourdomain.com/backend/api/v1/auth/google/callback  (production)
# 3. Copy the generated Client ID and Client Secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the magic-link email points users back to (the frontend, not the API).
FRONTEND_URL=http://localhost:3000
# true only once this runs behind real HTTPS - see services/auth.py.
COOKIE_SECURE=false
# Required in production - signs unsubscribe links (services/auth.py). If
# unset, a random key is generated per process and every restart invalidates
# links already sent. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Affiliate tagging (services/affiliate.py) - rewrites every outbound store
# link (search results, dashboard, email/Telegram alerts) right before it's
# shown to a user. Every value below is optional and independent: leaving
# any of them blank makes tagging a no-op for that store, links keep working
# exactly as today.
#
# Amazon Associates (afiliados.amazon.es): plain ?tag= query param.
AFFILIATE_AMAZON_TAG=
#
# PcComponentes runs its Spanish affiliate program on Awin
# (ui.awin.com/merchant-profile/20982 - that merchant id is already the
# default below, it's public). Sign up as an Awin publisher, then request to
# join the PcComponentes program from your Awin dashboard.
AFFILIATE_AWIN_PUBLISHER_ID=
AFFILIATE_AWIN_MID_PCCOMPONENTES=20982
#
# MediaMarkt.es runs its Spanish affiliate program on Tradedoubler, NOT Awin
# (publishers.tradedoubler.com/es) - a different network with its own ids.
AFFILIATE_TRADEDOUBLER_SITE_ID=
AFFILIATE_TRADEDOUBLER_PID_MEDIAMARKT=
#
# Worten.es: which network it uses wasn't confirmed as of 2026-07-15 (Worten
# PT is on Awin, but that's not proof ES is too). Fill in whichever one
# turns out to be correct once you apply - both are wired up, unused ones
# stay a no-op.
AFFILIATE_AWIN_MID_WORTEN=
AFFILIATE_TRADEDOUBLER_PID_WORTEN=
#
# ANY other scraped store can be monetized the same way without code changes:
# services/affiliate.py picks up every AFFILIATE_AWIN_MID_<STORE> /
# AFFILIATE_TRADEDOUBLER_PID_<STORE> var it finds. <STORE> must match the
# store's hostname with dots/dashes removed - examples (uncomment + fill in
# the id from your network dashboard once accepted into each program):
# AFFILIATE_AWIN_MID_DECATHLON=
# AFFILIATE_AWIN_MID_DRUNI=
# AFFILIATE_AWIN_MID_PRIMOR=
# AFFILIATE_AWIN_MID_CASADELLIBRO=
# AFFILIATE_TRADEDOUBLER_PID_IKEA=
# AFFILIATE_TRADEDOUBLER_PID_SPRINTERSPORTS=
