DATABASE_URL=postgresql+asyncpg://trendbuy:trendbuy@localhost:5432/trendbuy
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=123456789
# Verifies incoming webhook calls really come from Telegram (see
# api/telegram.py + services/notifier.py::set_telegram_webhook) - required
# for per-user Telegram linking to work, not just the broadcast bot above.
# Also needs FRONTEND_URL below to be a real public HTTPS URL (Telegram
# refuses localhost/http webhooks). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=
# Optional: only needed if Expo push receipts should be authenticated (Expo access token).
EXPO_ACCESS_TOKEN=

# Magic-link login emails + per-favorite deal alerts. Any SMTP relay works
# (Gmail app password, Mailgun, Brevo, SES...) - if left blank, emails are
# just logged as "not sent" instead of failing the request.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Where the magic-link email points users back to (the frontend, not the API).
FRONTEND_URL=http://localhost:3000
# true only once this runs behind real HTTPS - see services/auth.py.
COOKIE_SECURE=false
# Required in production - signs unsubscribe links (services/auth.py). If
# unset, a random key is generated per process and every restart invalidates
# links already sent. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
